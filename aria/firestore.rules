rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidChatMessage() {
      let data = request.resource.data;
      return data.keys().hasAll(['role', 'content', 'timestamp', 'sessionId', 'userId'])
        && data.role in ['user', 'assistant']
        && data.content is string
        && data.content.size() > 0
        && data.content.size() <= 10000;
    }

    // ── Users ─────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);

      // Chat sessions
      match /chatSessions/{sessionId} {
        allow read, write: if isAuthenticated() && isOwner(userId);

        // Messages within a session — read only by owner
        // Writes are done server-side via Cloud Functions only
        match /messages/{messageId} {
          allow read: if isAuthenticated() && isOwner(userId);
          allow write: if false; // Cloud Functions only
        }
      }

      // Tasks
      match /tasks/{taskId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      // Reminders
      match /reminders/{reminderId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      // Contacts / Relationship Memory
      match /contacts/{contactId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      // Vault documents metadata
      match /vaultItems/{itemId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      // User profile and preferences
      match /profile/{doc} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      // Financial records
      match /financials/{doc} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      // Health records
      match /health/{doc} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      // FCM notification tokens
      match /notificationTokens/{tokenId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      // Contacts — read only by owner; writes via Action Engine (client reads allowed for UI)
      match /contacts/{contactId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow write: if false; // Cloud Functions (executeAction) only
      }

      // Relationship memory notes — read only by owner; writes via Action Engine
      match /relationshipMemory/{memoryId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow write: if false; // Cloud Functions (executeAction) only
      }

      // Daily briefings — written by generateDailyBriefing Cloud Function
      match /briefings/{briefingId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow write: if false; // Cloud Functions only
      }
    }

    // ── Activity Logs (Action Engine audit trail) ─────────────────
    // Written exclusively by Cloud Functions (firebase-admin bypasses rules).
    // Users may read their own logs; no client writes allowed.
    match /activityLogs/{logId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false; // Cloud Functions (admin SDK) only
    }

    // ── Security / Multi-Tenant Platform (Phase 5.2) ──────────────
    // All reads and writes for tenants/** go exclusively through
    // securityApi.ts Cloud Functions, which use the Admin SDK (and so
    // bypass these rules) and enforce tenant-membership + RBAC checks
    // server-side via TenantEngine.requireIdentity / RBACEngine.
    //
    // Client-side direct Firestore access is intentionally denied for
    // every subcollection here — there is no safe per-document rule we
    // can express that reconstructs "does this identity belong to this
    // tenant AND does its role include the right permission" without
    // duplicating the RBAC engine's logic in security rules (which the
    // task spec explicitly forbids: no duplicated permission logic).
    // This is conservative-by-design: it trades client read performance
    // for a single source of truth for authorization. If real-time listeners
    // are ever needed here, the path forward is read-only rules scoped to
    // `identities/{identityId}` matched by `request.auth.uid`, not a general
    // tenant-wide allow.
    match /tenants/{tenantId} {
      allow read, write: if false; // Cloud Functions (Admin SDK) only

      match /identities/{identityId} {
        allow read, write: if false; // Cloud Functions only
      }
      match /roles/{roleId} {
        allow read, write: if false; // Cloud Functions only
      }
      match /roleAssignments/{assignmentId} {
        allow read, write: if false; // Cloud Functions only
      }
      match /policies/{policyId} {
        allow read, write: if false; // Cloud Functions only
      }
      match /sessions/{sessionId} {
        allow read, write: if false; // Cloud Functions only
      }
      match /groups/{groupId} {
        allow read, write: if false; // Cloud Functions only
      }
      match /serviceAccounts/{serviceAccountId} {
        allow read, write: if false; // Cloud Functions only
      }
      // Append-only audit log — no client read or write under any circumstance.
      match /securityAudit/{eventId} {
        allow read, write: if false; // Cloud Functions only; append-only via SecurityAudit.record()
      }

      // ── Marketplace (Phase 5.3) tenant-scoped collections ───────
      // Same conservative deny-by-default rationale as the rest of
      // tenants/{tenantId}/** above: all reads/writes for installed
      // skills, permission grants, usage, and audit go exclusively
      // through marketplaceApi.ts Cloud Functions (Admin SDK), which
      // enforce tenant membership via TenantEngine.requireIdentity and
      // permission checks via RBACEngine — never reconstructed here.
      match /installedSkills/{installationId} {
        allow read, write: if false; // Cloud Functions only
      }
      match /skillPermissions/{permissionId} {
        allow read, write: if false; // Cloud Functions only
      }
      match /skillUsage/{usageId} {
        allow read, write: if false; // Cloud Functions only
      }
      // Append-only audit log — mirrors securityAudit's contract.
      match /skillAudit/{auditId} {
        allow read, write: if false; // Cloud Functions only; append-only via SkillInstaller.writeAuditEvent()
      }

      // ── AI Gateway (Phase 5.4) tenant-scoped collections ────────
      // Same conservative deny-by-default rationale as the rest of
      // tenants/{tenantId}/** above: all reads/writes for AI usage,
      // policy, provider health, and fallback events go exclusively
      // through aiGatewayApi.ts Cloud Functions (Admin SDK), which
      // enforce tenant membership via TenantEngine.requireIdentity and
      // permission checks via RBACEngine (security.manage for policy
      // mutation) — never reconstructed here. No client ever reads or
      // writes these paths directly, which also keeps usage/cost data
      // and provider health signals from leaking between tenants.
      match /aiUsage/{usageId} {
        allow read, write: if false; // Cloud Functions only
      }
      match /aiPolicies/{policyId} {
        allow read, write: if false; // Cloud Functions only
      }
      match /aiProviderHealth/{providerId} {
        allow read, write: if false; // Cloud Functions only
      }
      // Append-only fallback-event log — mirrors securityAudit's contract.
      match /aiFallbackEvents/{eventId} {
        allow read, write: if false; // Cloud Functions only; append-only via ModelFallbackManager.logFallbackEvent()
      }

      // ── Computer Control (Phase 5.5) tenant-scoped collections ──────
      // Conservative deny-by-default — same rationale as all prior
      // tenants/{tenantId}/** blocks: all reads/writes for computer
      // agents, sessions, actions, approvals, and audit go exclusively
      // through computerControlApi.ts Cloud Functions (Admin SDK), which
      // enforce tenant membership via TenantEngine.requireIdentity and
      // RBAC via RBACEngine before any read or write.
      //
      // credentialAccess is unconditionally blocked at the engine layer
      // (ComputerSafetyGuard) regardless of these rules. These rules
      // add an additional layer of defence-in-depth: no client can
      // read or write computer-control data directly, preventing any
      // attempt to observe audit trails or spoof approval states from
      // the client side.
      match /computerAgents/{agentId} {
        allow read, write: if false; // Cloud Functions only — local agent registrations (placeholder)
      }
      match /computerSessions/{sessionId} {
        allow read, write: if false; // Cloud Functions only — computer control sessions
      }
      match /computerActions/{actionId} {
        allow read, write: if false; // Cloud Functions only — planned/executed computer actions
      }
      match /computerApprovals/{approvalId} {
        allow read, write: if false; // Cloud Functions only — computer action approvals
      }
      // Append-only audit log — mirrors securityAudit's contract.
      match /computerAudit/{auditId} {
        allow read, write: if false; // Cloud Functions only; append-only via ComputerAudit.record()
      }
      match /browserExtensions/{extensionId} {
        allow read, write: if false; // Cloud Functions only — browser extension registrations (placeholder)
      }
      match /computerPolicies/{policyId} {
        allow read, write: if false; // Cloud Functions only — computer control policies
      }

      // ── Computer Control (Phase 5.6) document bridge + generated files ──
      // Conservative deny-by-default — same rationale as all prior
      // computer control collections. Analysis results and generated file
      // metadata are written exclusively by Cloud Functions (Admin SDK)
      // via ComputerDocumentBridge. No raw file content is persisted.
      match /computerDocuments/{documentId} {
        allow read, write: if false; // Cloud Functions only — document bridge analysis records
      }
      match /computerGeneratedFiles/{fileId} {
        allow read, write: if false; // Cloud Functions only — generated file/report records
      }
    }

    // ── Marketplace catalog (Phase 5.3) — public read, CF-write-only ──
    // Marketplace listings are discoverable by any authenticated user;
    // all mutations (publish/approve/reject/update) go exclusively
    // through marketplaceApi.ts Cloud Functions using the Admin SDK.
    // Paths mirror MarketplaceRegistry.ts exactly: a fixed top-level
    // "container" doc (items/publishers/categories/reviews) holding a
    // same-named subcollection of records.
    match /marketplace/items {
      match /items/{itemId} {
        allow read: if isAuthenticated();
        allow write: if false; // Cloud Functions only
      }
    }
    match /marketplace/publishers {
      match /publishers/{publisherId} {
        allow read: if isAuthenticated();
        allow write: if false; // Cloud Functions only
      }
    }
    match /marketplace/categories {
      match /categories/{categoryId} {
        allow read: if isAuthenticated();
        allow write: if false; // Cloud Functions only
      }
    }
    match /marketplace/reviews {
      match /reviews/{reviewId} {
        allow read: if isAuthenticated();
        allow write: if false; // Cloud Functions only
      }
    }

    // ── AI Gateway global catalog (Phase 5.4) — public read, CF-write-only ──
    // Mirrors the marketplace catalog section above exactly: model/provider
    // metadata is discoverable by any authenticated user (needed for the
    // AIGatewayDashboard's model catalog table and provider health cards);
    // all mutations go exclusively through aiGatewayApi.ts Cloud Functions.
    match /aiGateway/models {
      match /models/{modelId} {
        allow read: if isAuthenticated();
        allow write: if false; // Cloud Functions only
      }
    }
    match /aiGateway/providers {
      match /providers/{providerId} {
        allow read: if isAuthenticated();
        allow write: if false; // Cloud Functions only
      }
    }

    // ── Phase 5.7: Meeting Agent — deny-by-default, CF/Admin SDK only ────────
    // All meeting data is sensitive (transcripts, summaries, action items).
    // Client SDKs cannot read or write any meeting collections directly.
    // All access goes through meetingAgentApi.ts Cloud Functions which verify
    // request.auth and TenantEngine.requireIdentity before any read/write.
    //
    // Collections:
    //   tenants/{tenantId}/meetingSessions/{sessionId}
    //   tenants/{tenantId}/meetingTranscripts/{transcriptId}
    //   tenants/{tenantId}/meetingSummaries/{summaryId}
    //   tenants/{tenantId}/meetingActionItems/{actionItemId}
    //   tenants/{tenantId}/meetingParticipants/{participantId}
    //   tenants/{tenantId}/meetingAudit/{auditId}
    //   tenants/{tenantId}/meetingFollowUps/{followUpId}
    match /tenants/{tenantId}/meetingSessions/{sessionId} {
      allow read, write: if false; // Cloud Functions / Admin SDK only
    }
    match /tenants/{tenantId}/meetingTranscripts/{transcriptId} {
      // Transcripts are especially sensitive — no client read/write ever.
      allow read, write: if false; // Cloud Functions / Admin SDK only
    }
    match /tenants/{tenantId}/meetingSummaries/{summaryId} {
      allow read, write: if false; // Cloud Functions / Admin SDK only
    }
    match /tenants/{tenantId}/meetingActionItems/{actionItemId} {
      allow read, write: if false; // Cloud Functions / Admin SDK only
    }
    match /tenants/{tenantId}/meetingParticipants/{participantId} {
      allow read, write: if false; // Cloud Functions / Admin SDK only
    }
    match /tenants/{tenantId}/meetingAudit/{auditId} {
      // Audit trail is immutable from client perspective.
      allow read, write: if false; // Cloud Functions / Admin SDK only
    }
    match /tenants/{tenantId}/meetingFollowUps/{followUpId} {
      allow read, write: if false; // Cloud Functions / Admin SDK only
    }

    // ── Deny everything else ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
